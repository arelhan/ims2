# Docker ortamı için environment değişkenleri
# Bu dosyayı .env olarak kopyalayın: cp .env.docker .env

# ZORUNLU: Güçlü bir JWT secret belirleyin
JWT_SECRET=degistir-bunu-guclu-bir-secret-yap

# Uygulamaya dışarıdan erişilecek URL (sunucu IP veya domain)
# QR kodlarda kullanılır
PUBLIC_APP_URL=http://localhost:3002

# Admin panelinin adresi (CORS için)
ADMIN_PANEL_URL=http://localhost:3001
